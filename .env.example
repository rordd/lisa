# ZeroClaw Environment Variables
# Copy this file to `.env` and fill in your local values.
# Never commit `.env` or any real secrets.

# ── Core Runtime ──────────────────────────────────────────────
# Provider key resolution at runtime:
# 1) explicit key passed from config/CLI
# 2) provider-specific env var (OPENROUTER_API_KEY, OPENAI_API_KEY, ...)
# 3) generic fallback env vars below

# Generic fallback API key (used when provider-specific key is absent)
API_KEY=your-api-key-here
# ZEROCLAW_API_KEY=your-api-key-here

# Default provider/model (can be overridden by CLI flags)
# ZEROCLAW_PROVIDER=openrouter
# ZEROCLAW_MODEL=anthropic/claude-sonnet-4-6
# ZEROCLAW_TEMPERATURE=0.7

# Workspace directory override
# ZEROCLAW_WORKSPACE=/path/to/workspace

# Log level (default: info)
# RUST_LOG=info                        # trace | debug | info | warn | error

# ══════════════════════════════════════════════════════════════
# PROVIDERS — Main
# ══════════════════════════════════════════════════════════════

# ── Anthropic ────────────────────────────────────────────────
# Models: claude-sonnet-4-6, claude-opus-4-6, etc.
# ZEROCLAW_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_OAUTH_TOKEN=...
# ZEROCLAW_MODEL=claude-sonnet-4-6
# ZEROCLAW_TEMPERATURE=0.7
#
# Extended thinking (Anthropic only)
# ANTHROPIC_THINKING_MODE=adaptive    # adaptive | enabled | disabled (default: off)
# ANTHROPIC_THINKING_BUDGET=10000     # budget_tokens for "enabled" mode only
# ANTHROPIC_EFFORT=high               # low | medium | high | max

# ── OpenAI ───────────────────────────────────────────────────
# Models: gpt-5.4, gpt-5, gpt-4o, o1, o3, o4-mini, etc.
# NOTE: GPT-5 and later require temperature=1 (API rejects other values)
# ZEROCLAW_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# ZEROCLAW_MODEL=gpt-5.4
# ZEROCLAW_TEMPERATURE=1              # GPT-5+: must be 1 | GPT-4o: 0.0~2.0
#
# Reasoning (GPT-5/Codex models)
# ZEROCLAW_REASONING_ENABLED=true     # true | false
# ZEROCLAW_REASONING_EFFORT=medium    # none | minimal | low | medium | high | xhigh
#
# Service tier (OpenAI only — priority processing)
# ZEROCLAW_SERVICE_TIER=default       # priority (~1.5x faster, ~2x cost) | default | auto | flex

# ── Azure OpenAI ─────────────────────────────────────────────
# Uses OpenAI models via Azure endpoints
# NOTE: GPT-5 deployments require temperature=1
# ZEROCLAW_PROVIDER=openai
# OPENAI_API_KEY=your-azure-key
# ZEROCLAW_MODEL=your-deployment-name
# ZEROCLAW_TEMPERATURE=1              # GPT-5+: must be 1 | GPT-4o: 0.0~2.0
# ZEROCLAW_CUSTOM_AUTH_HEADER=api-key  # Azure uses "api-key" header instead of "Authorization: Bearer"
# Set provider URL in config.toml: provider_url = "https://YOUR.openai.azure.com/openai/deployments/YOUR_DEPLOYMENT"
#
# Reasoning (Azure custom provider — uses reasoning_level, not reasoning_effort)
# ZEROCLAW_REASONING_ENABLED=true               # true | false
# ZEROCLAW_CUSTOM_REASONING_EFFORT=medium        # none | minimal | low | medium | high (xhigh → clamped to high)
#
# Service tier (if Azure supports it for your deployment)
# ZEROCLAW_SERVICE_TIER=default       # priority (~1.5x faster, ~2x cost) | default | auto | flex

# ── Google Gemini ────────────────────────────────────────────
# Models: gemini-2.5-flash, gemini-2.5-pro, etc.
# ZEROCLAW_PROVIDER=gemini
# GEMINI_API_KEY=...
# GOOGLE_API_KEY=...
# ZEROCLAW_MODEL=gemini-2.5-flash
# ZEROCLAW_TEMPERATURE=0.7

# ══════════════════════════════════════════════════════════════
# PROVIDERS — Others
# ══════════════════════════════════════════════════════════════

# ── OpenRouter ───────────────────────────────────────────────
# Multi-provider gateway — access OpenAI/Anthropic/Google/open-source models
# OPENROUTER_API_KEY=sk-or-v1-...

# ── DeepSeek ─────────────────────────────────────────────────
# DEEPSEEK_API_KEY=...

# ── Z.AI GLM ────────────────────────────────────────────────
# API key format: id.secret (e.g., abc123.xyz789)
# Models: glm-5, glm-4.7, glm-4-plus, glm-4-flash
# ZAI_API_KEY=your-id.secret
# GLM_API_KEY=...

# ── MiniMax ──────────────────────────────────────────────────
# MINIMAX_API_KEY=...
# MINIMAX_OAUTH_TOKEN=...
# MINIMAX_OAUTH_REFRESH_TOKEN=...
# MINIMAX_OAUTH_REGION=global         # global | cn

# ── Other Providers ──────────────────────────────────────────
# MISTRAL_API_KEY=...
# XAI_API_KEY=...
# GROQ_API_KEY=...
# TOGETHER_API_KEY=...
# FIREWORKS_API_KEY=...
# PERPLEXITY_API_KEY=...
# COHERE_API_KEY=...
# VENICE_API_KEY=...
# MOONSHOT_API_KEY=...
# QIANFAN_API_KEY=...
# DASHSCOPE_API_KEY=...
# SYNTHETIC_API_KEY=...
# OPENCODE_API_KEY=...
# OPENCODE_GO_API_KEY=...
# VERCEL_API_KEY=...
# CLOUDFLARE_API_KEY=...

# ══════════════════════════════════════════════════════════════
# INFRASTRUCTURE
# ══════════════════════════════════════════════════════════════

# ── Gateway ──────────────────────────────────────────────────
# ZEROCLAW_GATEWAY_PORT=3000
# ZEROCLAW_GATEWAY_HOST=127.0.0.1
# ZEROCLAW_ALLOW_PUBLIC_BIND=false

# ── Storage ─────────────────────────────────────────────────
# ZEROCLAW_STORAGE_PROVIDER=sqlite
# ZEROCLAW_STORAGE_DB_URL=postgres://localhost/zeroclaw
# ZEROCLAW_STORAGE_CONNECT_TIMEOUT_SECS=5

# ── Proxy ──────────────────────────────────────────────────
# ZEROCLAW_PROXY_ENABLED=false
# ZEROCLAW_HTTP_PROXY=http://proxy.example.com:8080
# ZEROCLAW_HTTPS_PROXY=http://proxy.example.com:8080
# ZEROCLAW_ALL_PROXY=socks5://proxy.example.com:1080
# ZEROCLAW_NO_PROXY=localhost,127.0.0.1
# ZEROCLAW_PROXY_SCOPE=zeroclaw       # environment | zeroclaw | services
# ZEROCLAW_PROXY_SERVICES=openai,anthropic

# ── Web Search ───────────────────────────────────────────────
# WEB_SEARCH_ENABLED=true
# WEB_SEARCH_PROVIDER=duckduckgo      # duckduckgo (free) | brave (API key required)
# WEB_SEARCH_MAX_RESULTS=5
# WEB_SEARCH_TIMEOUT_SECS=15
# BRAVE_API_KEY=your-brave-search-api-key

# ══════════════════════════════════════════════════════════════
# SKILLS & INTEGRATIONS
# ══════════════════════════════════════════════════════════════

# ── Skill API Keys ───────────────────────────────────────────
# Used by skill scripts. Must be listed in
# config.toml [autonomy] shell_env_passthrough to be visible.
#
# Google (Places, Static Maps, Routes, Directions, YouTube Data API v3)
# GOOGLE_MAPS_API_KEY=AIza...
#
# Kakao (Mobility directions, Geocode)
# KAKAO_REST_API_KEY=...
#
# Naver (Shopping, Blog, News search)
# NAVER_CLIENT_ID=...
# NAVER_CLIENT_SECRET=...
#
# KOBIS (Korean Box Office — rankings, movie search/detail)
# KOBIS_API_KEY=...
#
# KMDb (Korean Movie Database — posters, cast/crew, plot)
# KMDB_API_KEY=...
#
# gog (Google Workspace CLI — Gmail, Calendar, Drive)
# GOG_ACCOUNT=your@gmail.com
# GOG_KEYRING_PASSWORD=...
# GOG_KEYRING_BACKEND=file

# ── Pushover ─────────────────────────────────────────────────
# PUSHOVER_TOKEN=your-pushover-app-token
# PUSHOVER_USER_KEY=your-pushover-user-key

# ── Docker Compose ───────────────────────────────────────────
# HOST_PORT=3000
