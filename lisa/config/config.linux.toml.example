# Lisa config — Linux (Ubuntu) target
# Installed to ~/.zeroclaw/config.toml on the target by deploy-linux.sh.

# === Provider ===
default_provider = "custom:https://tvdevops.openai.azure.com/openai/v1"
api_key = "<Azure API Key>"
default_model = "gpt-5-mini"
default_temperature = 1.0

[channels_config]
cli = true

# === Telegram ===
# Telegram is not accessible from the internal company network
# [channels_config.telegram]
# bot_token = "YOUR_BOT_TOKEN"
# allowed_users = ["YOUR_USER_ID"]
# mention_only = false
# stream_mode = "partial"
# ack_enabled = true

[gateway]
port = 42617
bind = "127.0.0.1"

# === Autonomy ===
[autonomy]
level = "full"
workspace_only = false
allowed_commands = ["git", "npm", "cargo", "ls", "cat", "grep", "find", "echo", "pwd", "wc", "head", "tail", "date", "gog", "memo", "remindctl", "jq", "python3", "bash"]
auto_approve = ["file_read", "memory_recall", "web_fetch", "web_search", "web_search_tool", "skills", "shell"]
shell_env_passthrough = ["GOG_ACCOUNT", "GOG_KEYRING_PASSWORD", "GOG_KEYRING_BACKEND"]
forbidden_paths = []
max_actions_per_hour = 100
max_cost_per_day_cents = 1000

# === Memory ===
[memory]
backend = "markdown"
auto_save = true

# === Skills ===
[skills]
allow_scripts = true

# === Security ===
[security.sandbox]
enabled = false
