# Lisa target environment variables
# Copy to lisa.env and fill in values before deploy.
# This file is transferred to /home/root/lisa/lisa.env on the target
# and sourced by start-lisa.sh / lisa-agent.sh at startup.

# --- Google Calendar (gog) ---
# Required for calendar skill. Get your account email and keyring password
# after running: gog auth add <email> --services calendar --manual
#export GOG_ACCOUNT=your@gmail.com
#export GOG_KEYRING_PASSWORD=your-keyring-password
#export GOG_KEYRING_BACKEND=file
