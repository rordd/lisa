        KEY=$(json_val "$PAYLOAD" key)
        case "$KEY" in
            [0-9])
                # Channel digit input — accumulate in temp
                PENDING="/tmp/luna-send-mock-chdigit"
                [ -f "$PENDING" ] && PREV=$(cat "$PENDING") || PREV=""
                echo "${PREV}${KEY}" > "$PENDING"
                ;;
