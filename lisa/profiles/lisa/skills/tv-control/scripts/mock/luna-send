#!/bin/bash
# Mock luna-send for non-webOS environments (Linux dev/test)
# Parses URI and payload, returns realistic JSON responses.
# Place this directory first in PATH to intercept luna-send calls.

# Parse args: luna-send [-n count] [-i] [-f] <uri> <payload>
URI=""
PAYLOAD=""
while [ $# -gt 0 ]; do
    case "$1" in
        -n) shift; shift ;;  # skip -n <count>
        -i|-f) shift ;;      # skip flags
        luna://*) URI="$1"; shift ;;
        *) PAYLOAD="$1"; shift ;;
    esac
done

# Track state in a temp file for realistic mock behavior
STATE_FILE="/tmp/luna-send-mock-state"
if [ ! -f "$STATE_FILE" ]; then
    echo '{"volume":10,"channel":7,"foreground":"com.webos.app.livetv"}' > "$STATE_FILE"
fi

read_state() {
    cat "$STATE_FILE"
}

# Helper: extract JSON field value (simple, no jq dependency)
json_val() {
    echo "$1" | sed -n 's/.*"'"$2"'"[[:space:]]*:[[:space:]]*\("*[^",}]*"*\).*/\1/p' | tr -d '"'
}

STATE=$(read_state)
VOLUME=$(json_val "$STATE" volume)
CHANNEL=$(json_val "$STATE" channel)
FOREGROUND=$(json_val "$STATE" foreground)

