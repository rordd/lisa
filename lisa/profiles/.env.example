# Lisa secret configuration
# Copy this file to .env and fill in the values
# cp profiles/.env.example .env

# === Required ===
ZEROCLAW_API_KEY=                # LLM API key
ZEROCLAW_PROVIDER=gemini         # gemini, openai, anthropic, ollama, openrouter, custom:azure, etc.
ZEROCLAW_MODEL=gemini-2.5-flash  # Model name for the provider

# === Azure OpenAI (when using custom:azure) ===
# AZURE_OPENAI_BASE_URL=https://<resource>.openai.azure.com/openai/deployments/<deployment>/chat/completions?api-version=2024-02-01
# AZURE_OPENAI_API_KEY=           # Azure-specific key (may differ from ZEROCLAW_API_KEY)

# === Telegram (optional) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=          # Comma-separated, e.g., 123456,789012
TELEGRAM_MENTION_ONLY=true

# === Gateway (optional) ===
# GATEWAY_PORT=42617

# === Weather (optional) ===
# WEATHER_LOCATION=Seoul Gangseo-gu
