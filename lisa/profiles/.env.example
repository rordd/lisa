# Lisa environment variables
# Copy to .env at repo root and fill in your values:
#   cp lisa/profiles/.env.example .env
#
# This single file covers all environments (local dev, ARM64 board, Linux server).
# Fill in only what you need — unused variables are safely ignored.

# ═══════════════════════════════════════════
# LLM Provider (required — pick one section)
# ═══════════════════════════════════════════

# --- Google Gemini (home/default) ---
ZEROCLAW_API_KEY=
ZEROCLAW_PROVIDER=gemini
ZEROCLAW_MODEL=gemini-2.5-flash

# --- Azure OpenAI (office/board) ---
# Uncomment and fill these, comment out the Gemini section above.
# ZEROCLAW_PROVIDER=custom:azure
# ZEROCLAW_MODEL=gpt-5-mini
# AZURE_OPENAI_BASE_URL=https://<resource>.openai.azure.com/openai/v1
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_AUTH_HEADER=api-key    # Azure uses "api-key" header instead of "Bearer"

# ═══════════════════════════════════════════
# Telegram (optional)
# ═══════════════════════════════════════════
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=          # Comma-separated user IDs, e.g. 123456,789012
TELEGRAM_MENTION_ONLY=true

# ═══════════════════════════════════════════
# Google Calendar — gog (optional)
# ═══════════════════════════════════════════
# Required for calendar skill.
# Run: gog auth add <email> --services calendar --manual
# GOG_ACCOUNT=your@gmail.com
# GOG_KEYRING_PASSWORD=
# GOG_KEYRING_BACKEND=file
