# Lisa environment variables
# Copy to .env at your zeroclaw config dir and fill in your values:
#   cp lisa/profiles/.env.example ~/.zeroclaw/.env
#
# This single file covers all environments (local dev, ARM64 board, Linux server).
# Fill in only what you need — unused variables are safely ignored.
# All variables use "export" so `source .env` makes them available to child processes.

# ══════════════════════════════════════════════════════════════
# LLM PROVIDERS — pick one section, comment out the rest
# ══════════════════════════════════════════════════════════════

# ── Anthropic ────────────────────────────────────────────────
# Models: claude-sonnet-4-6, claude-opus-4-6, etc.
# export ZEROCLAW_PROVIDER=anthropic
# export ANTHROPIC_API_KEY=sk-ant-...
# export ZEROCLAW_MODEL=claude-sonnet-4-6
# export ZEROCLAW_TEMPERATURE=0.7
#
# Extended thinking (Anthropic only)
# export ANTHROPIC_THINKING_MODE=adaptive    # adaptive | enabled | disabled (default: off)
# export ANTHROPIC_THINKING_BUDGET=10000     # budget_tokens for "enabled" mode only
# export ANTHROPIC_EFFORT=high               # low | medium | high | max

# ── Google Gemini ────────────────────────────────────────────
# Models: gemini-2.5-flash, gemini-2.5-pro, etc.
# export ZEROCLAW_PROVIDER=gemini
# export ZEROCLAW_API_KEY=AIza...
# export ZEROCLAW_MODEL=gemini-2.5-flash
# export ZEROCLAW_TEMPERATURE=0.7

# ── OpenAI ───────────────────────────────────────────────────
# Models: gpt-5.4, gpt-5, gpt-4o, o1, o3, o4-mini, etc.
# NOTE: GPT-5+ require temperature=1 (API rejects other values)
# export ZEROCLAW_PROVIDER=openai
# export OPENAI_API_KEY=sk-...
# export ZEROCLAW_MODEL=gpt-5.4
# export ZEROCLAW_TEMPERATURE=1              # GPT-5+: must be 1 | GPT-4o: 0.0~2.0
#
# Reasoning (GPT-5/Codex models)
# export ZEROCLAW_REASONING_ENABLED=true     # true | false
# export ZEROCLAW_REASONING_EFFORT=medium    # none | minimal | low | medium | high | xhigh
#
# Service tier (OpenAI only — priority processing)
# export ZEROCLAW_SERVICE_TIER=default       # priority (~1.5x faster, ~2x cost) | default | auto | flex

# ── Azure OpenAI ─────────────────────────────────────────────
# Uses OpenAI models via Azure endpoints.
# Set provider URL in config.toml: provider_url = "https://YOUR.openai.azure.com/openai/deployments/YOUR_DEPLOYMENT"
# NOTE: GPT-5 deployments require temperature=1
# export ZEROCLAW_PROVIDER=openai
# export OPENAI_API_KEY=your-azure-key
# export ZEROCLAW_MODEL=your-deployment-name
# export ZEROCLAW_TEMPERATURE=1
# export ZEROCLAW_CUSTOM_AUTH_HEADER=api-key  # Azure uses "api-key" header instead of "Authorization: Bearer"
#
# Reasoning (Azure — uses reasoning_level, not reasoning_effort)
# export ZEROCLAW_REASONING_ENABLED=true
# export ZEROCLAW_CUSTOM_REASONING_EFFORT=medium  # none | minimal | low | medium | high (xhigh → clamped to high)
#
# Private endpoint (optional)
# export AZURE_PRIVATE_ENDPOINT=10.182.173.75

# ══════════════════════════════════════════════════════════════
# SKILLS
# ══════════════════════════════════════════════════════════════

# Force all skill tools to use tool_choice: "required" on the first LLM turn.
# export ZEROCLAW_TOOL_CHOICE_REQUIRED=true  # true | false (default: false)

# Skill prompt injection mode
# export ZEROCLAW_SKILLS_PROMPT_MODE=compact  # compact (default) | full

# ── Skill API Keys ───────────────────────────────────────────
# Must be listed in config.toml [autonomy] shell_env_passthrough to be visible.
#
# Google (Places, Static Maps, Routes, Directions, YouTube Data API v3)
# export GOOGLE_MAPS_API_KEY=AIza...
#
# Kakao (Mobility directions, Geocode)
# export KAKAO_REST_API_KEY=...
#
# Naver (Shopping, Blog, News search)
# export NAVER_CLIENT_ID=...
# export NAVER_CLIENT_SECRET=...
#
# KOBIS (Korean Box Office — rankings, movie search/detail)
# export KOBIS_API_KEY=...
#
# KMDb (Korean Movie Database — posters, cast/crew, plot)
# export KMDB_API_KEY=...

# ══════════════════════════════════════════════════════════════
# TELEGRAM
# ══════════════════════════════════════════════════════════════
# Not accessible from company internal network — disabled by default for office/board.
# export TELEGRAM_BOT_TOKEN=
# export TELEGRAM_ALLOWED_USERS=             # Comma-separated user IDs
# export TELEGRAM_MENTION_ONLY=true

# ══════════════════════════════════════════════════════════════
# GOOGLE CALENDAR (gog)
# ══════════════════════════════════════════════════════════════
# Run: GOG_KEYRING_PASSWORD=xxx gog auth add <email> --services calendar
# export GOG_ACCOUNT=your@gmail.com
# export GOG_KEYRING_PASSWORD=your-keyring-password
# export GOG_KEYRING_BACKEND=file

# ══════════════════════════════════════════════════════════════
# GATEWAY
# ══════════════════════════════════════════════════════════════
# export ZEROCLAW_GATEWAY_PORT=42617
# export ZEROCLAW_GATEWAY_HOST=127.0.0.1

# ══════════════════════════════════════════════════════════════
# LOGGING
# ══════════════════════════════════════════════════════════════
# export RUST_LOG=info                       # trace | debug | info | warn | error
