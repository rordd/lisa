# Lisa environment variables
# Copy to .env at repo root and fill in your values:
#   cp lisa/profiles/.env.example .env
#
# This single file covers all environments (local dev, ARM64 board, Linux server).
# Fill in only what you need — unused variables are safely ignored.
# All variables use "export" so `source .env` makes them available to child processes.

# ═══════════════════════════════════════════
# LLM Provider (required — pick one section)
# ═══════════════════════════════════════════

# --- Google Gemini (home/default) ---
# export ZEROCLAW_API_KEY=
# export ZEROCLAW_PROVIDER=gemini
# export ZEROCLAW_MODEL=gemini-2.5-flash

# --- Azure OpenAI (office/board) ---
# Uncomment and fill these, comment out the Gemini section above.
# export ZEROCLAW_API_KEY=<azure-api-key>
# export ZEROCLAW_PROVIDER=custom:https://<resource>.openai.azure.com/openai/v1
# export ZEROCLAW_MODEL=gpt-5-mini
# export ZEROCLAW_TEMPERATURE=1                     # Required for reasoning models (gpt-5-mini, o-series)
# export AZURE_PRIVATE_ENDPOINT=<private-ip>        # Private endpoint IP for /etc/hosts (e.g. 10.182.173.75)
# export ZEROCLAW_CUSTOM_REASONING_EFFORT=minimal   # Reasoning effort: minimal, low, medium(default), high

# ═══════════════════════════════════════════
# Telegram (optional)
# ═══════════════════════════════════════════
# Telegram is not accessible from the internal company network, so it's disabled by default in the office/board profile. Enable if you want to use Telegram features and are not behind the company firewall.
# export TELEGRAM_BOT_TOKEN=
# export TELEGRAM_ALLOWED_USERS=          # Comma-separated user IDs, e.g. 123456,789012
# export TELEGRAM_MENTION_ONLY=true

# ═══════════════════════════════════════════
# Google Calendar — gog (optional)
# ═══════════════════════════════════════════
# Required for calendar skill.
# Run: gog auth add <email> --services calendar --manual
# export GOG_ACCOUNT=your@gmail.com
# export GOG_KEYRING_PASSWORD=your-keyring-password
# export GOG_KEYRING_BACKEND=file
