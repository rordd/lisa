# Lisa 시크릿 설정
# 이 파일을 .env로 복사하고 값을 채워넣으세요
# cp profiles/.env.example .env

# === 필수 ===
ZEROCLAW_API_KEY=                # LLM API 키
ZEROCLAW_PROVIDER=gemini         # gemini, openai, anthropic, ollama, openrouter, custom:azure 등
ZEROCLAW_MODEL=gemini-2.5-flash  # 프로바이더별 모델명

# === Azure OpenAI (custom:azure 사용 시) ===
# AZURE_OPENAI_BASE_URL=https://<리소스명>.openai.azure.com/openai/deployments/<배포명>/chat/completions?api-version=2024-02-01
# AZURE_OPENAI_API_KEY=           # Azure 전용 키 (ZEROCLAW_API_KEY와 다를 수 있음)

# === 텔레그램 (선택) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=          # 쉼표 구분, 예: 123456,789012
TELEGRAM_MENTION_ONLY=true

# === 게이트웨이 (선택) ===
# GATEWAY_PORT=42617

# === 날씨 (선택) ===
# WEATHER_LOCATION=서울 강서구
